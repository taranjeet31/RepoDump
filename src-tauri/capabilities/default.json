{
  "identifier": "default",
  "description": "Default permissions for RepoDump",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-read-dir",
    "fs:allow-write-file",
    "fs:allow-stat",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text"
  ]
}
